# Copy this file to .env. Never commit .env.
DATABASE_URL=ecto://postgres:postgres@127.0.0.1:55432/dramatizer_dev
TEST_DATABASE_URL=ecto://postgres:postgres@127.0.0.1:55432/dramatizer_test
PORT=4000
PHX_HOST=localhost
# Provider mode is explicit: only "fake" or "openai" are accepted.
# Any other value refuses to boot instead of silently falling back to fake.
# "openai" additionally requires OPENAI_API_KEY; the workspace header always
# shows the active mode ("Fake 模拟模式" or "OpenAI 已启用").
DRAMATIZER_PROVIDER=fake
# Optional absolute path override, for example D:/dramatizer-assets.
# DRAMATIZER_ASSET_STORE_ROOT=D:/dramatizer-assets
DRAMATIZER_PYTHON=python
DRAMATIZER_FFMPEG=ffmpeg
DRAMATIZER_FFPROBE=ffprobe
# OPENAI_API_KEY is required for scripts/real-smoke.ps1 or DRAMATIZER_PROVIDER=openai.
