        "asset_id": { "type": "string", "minLength": 1 },
        "source_attempt_id": { "type": "string", "minLength": 1 },
        "candidate_index": { "type": "integer", "minimum": 0 },
        "content_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "storage_uri": { "type": "string", "pattern": "^(s3|asset)://" },
        "finalized": { "const": true },
        "created_at": { "type": "string", "format": "date-time" },
        "extensions": { "$ref": "#/$defs/extensions" }
      },
      "additionalProperties": false
    },
    "callbackInboxRecord": {
      "type": "object",
      "required": ["id", "provider_id", "delivery_id", "provider_job_id", "signature_verified", "payload_hash", "status", "received_at", "extensions"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "provider_id": { "type": "string", "minLength": 1 },
        "delivery_id": { "type": "string", "minLength": 1 },
        "provider_job_id": { "type": "string", "minLength": 1 },
