        "publication_target_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "manifest_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "created_at": { "type": "string", "format": "date-time" },
        "extensions": { "$ref": "#/$defs/extensions" }
