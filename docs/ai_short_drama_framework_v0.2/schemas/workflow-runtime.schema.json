      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "release_candidate_id": { "type": "string", "minLength": 1 },
        "render_input_manifest_id": { "type": "string", "minLength": 1 },
        "export_asset_version_id": { "type": "string", "minLength": 1 },
        "export_content_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "release_gate_id": { "type": "string", "minLength": 1 },
        "release_gate_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "release_gate_input_closure_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "release_gate_status_at_creation": { "type": "string", "enum": ["ready", "waived"] },
        "release_gate_valid_until": { "type": "string", "format": "date-time" },
        "quality_report_id": { "type": "string", "minLength": 1 },
        "rights_gate_snapshot_id": { "type": "string", "minLength": 1 },
        "rights_gate_snapshot_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "rights_gate_valid_until": { "type": "string", "format": "date-time" },
        "asset_availability_snapshot_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
