        "aggregate_id": { "type": "string", "minLength": 1 },
        "event_type": { "type": "string", "minLength": 1 },
        "payload_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "status": { "type": "string", "enum": ["pending", "delivering", "delivered", "dead_letter"] },
        "delivery_attempts": { "type": "integer", "minimum": 0 },
        "next_delivery_at": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" },
