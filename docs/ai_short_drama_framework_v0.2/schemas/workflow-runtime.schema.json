        "render_profile_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "input_asset_version_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "rights_gate_snapshot_id": { "type": "string", "minLength": 1 },
        "rights_gate_snapshot_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "rights_gate_valid_until": { "type": "string", "format": "date-time" },
        "asset_availability_snapshot_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "review_decision_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
