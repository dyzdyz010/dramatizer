      "additionalProperties": false
    },
    "publishAttempt": {
      "type": "object",
      "required": ["id", "release_manifest_id", "manifest_hash", "release_gate_id", "release_gate_hash", "release_gate_valid_until", "publication_preflight_result", "publication_preflight_hash", "preflight_policy_revision_id", "asset_availability_snapshot_hash", "rights_gate_snapshot_hash", "waiver_set_hash", "review_decision_set_hash", "preflight_checked_at", "attempt_ordinal", "status", "platform", "account_id", "provider_submission_key", "created_at", "updated_at", "extensions"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "release_manifest_id": { "type": "string", "minLength": 1 },
        "manifest_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "release_gate_id": { "type": "string", "minLength": 1 },
        "release_gate_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "release_gate_valid_until": { "type": "string", "format": "date-time" },
        "publication_preflight_result": { "type": "string", "enum": ["passed", "failed"] },
        "publication_preflight_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "preflight_policy_revision_id": { "type": "string", "minLength": 1 },
        "asset_availability_snapshot_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "rights_gate_snapshot_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "waiver_set_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "review_decision_set_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "preflight_checked_at": { "type": "string", "format": "date-time" },
        "attempt_ordinal": { "type": "integer", "minimum": 1 },
        "previous_attempt_id": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["created", "submitting", "submitted", "published", "failed", "cancelling", "cancelled", "unknown_remote_state"] },
        "platform": { "type": "string", "minLength": 1 },
        "account_id": { "type": "string", "minLength": 1 },
        "provider_submission_key": { "type": "string", "minLength": 1 },
        "remote_publication_id": { "type": "string", "minLength": 1 },
        "error": { "$ref": "#/$defs/errorInfo" },
        "submitted_at": { "type": "string", "format": "date-time" },
        "finished_at": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "extensions": { "$ref": "#/$defs/extensions" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "enum": ["submitting", "submitted", "published", "cancelling", "cancelled", "unknown_remote_state"] } }, "required": ["status"] },
          "then": { "properties": { "publication_preflight_result": { "const": "passed" } } }
        },
        {
          "if": { "properties": { "attempt_ordinal": { "minimum": 2 } }, "required": ["attempt_ordinal"] },
          "then": { "required": ["previous_attempt_id"] }
        },
        {
          "if": { "properties": { "status": { "const": "published" } }, "required": ["status"] },
          "then": { "required": ["remote_publication_id", "finished_at"] }
        }
      ],
      "additionalProperties": false
    },
    "uploadIntent": {
      "type": "object",
      "required": ["id", "owner_type", "owner_id", "object_key", "expected_content_type", "expected_size_bytes", "expected_content_hash", "status", "expires_at", "created_at", "extensions"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "owner_type": { "type": "string", "enum": ["provider_attempt", "manual_node_run"] },
        "owner_id": { "type": "string", "minLength": 1 },
        "object_key": { "type": "string", "minLength": 1 },
        "expected_content_type": { "type": "string", "minLength": 1 },
        "expected_size_bytes": { "type": "integer", "minimum": 1 },
        "expected_content_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "status": { "type": "string", "enum": ["initiated", "uploaded", "finalizing", "finalized", "expired", "aborted"] },
        "asset_version_id": { "type": "string", "minLength": 1 },
        "expires_at": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" },
        "finalized_at": { "type": "string", "format": "date-time" },
        "extensions": { "$ref": "#/$defs/extensions" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "finalized" } }, "required": ["status"] },
          "then": { "required": ["asset_version_id", "finalized_at"] },
          "else": {
            "properties": {
              "asset_version_id": false,
              "finalized_at": false
            }
          }
        }
      ],
      "additionalProperties": false
    }
  }
