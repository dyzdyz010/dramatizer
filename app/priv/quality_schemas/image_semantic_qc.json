{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DramatizerImageSemanticQC",
  "type": "object",
  "additionalProperties": false,
  "required": ["dimensions"],
  "properties": {
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity_variant", "wardrobe", "location", "lighting", "key_props",
        "must_forbid", "composition", "camera", "action", "expression", "style", "artifacts"
      ],
      "properties": {
        "identity_variant": {"$ref": "#/$defs/evidence"},
        "wardrobe": {"$ref": "#/$defs/evidence"},
        "location": {"$ref": "#/$defs/evidence"},
        "lighting": {"$ref": "#/$defs/evidence"},
        "key_props": {"$ref": "#/$defs/evidence"},
        "must_forbid": {"$ref": "#/$defs/evidence"},
        "composition": {"$ref": "#/$defs/evidence"},
        "camera": {"$ref": "#/$defs/evidence"},
        "action": {"$ref": "#/$defs/evidence"},
        "expression": {"$ref": "#/$defs/evidence"},
        "style": {"$ref": "#/$defs/evidence"},
        "artifacts": {"$ref": "#/$defs/evidence"}
      }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "confidence", "reason", "advice"],
      "properties": {
        "status": {"type": "string", "enum": ["pass", "fail", "warning", "inconclusive"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "reason": {"type": "string"},
        "advice": {"type": "string"}
      }
    }
  }
}
