{
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "episode", "scenes", "story_events", "dialogue_events", "dependencies", "conflicts", "production_profile_override"],
  "properties": {
    "schema_version": {"type": "string", "enum": ["narrative-draft-v2"]},
    "episode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "logline", "summary", "opening_hook", "central_conflict", "ending_hook"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "logline": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "opening_hook": {"type": "string"},
        "central_conflict": {"type": "string", "minLength": 1},
        "ending_hook": {"type": "string"}
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "location_ref", "time_of_day", "goal", "summary", "source_semantics", "beats"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "location_ref": {"type": "string", "minLength": 1},
          "time_of_day": {"type": "string", "minLength": 1},
          "goal": {"type": "string", "minLength": 1},
          "summary": {"type": "string", "minLength": 1},
          "source_semantics": {"type": "string", "enum": ["source_grounded", "inferred", "creative"]},
          "beats": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "title", "goal", "summary", "story_event_ids"],
              "properties": {
                "id": {"type": "string", "minLength": 1},
                "title": {"type": "string", "minLength": 1},
                "goal": {"type": "string", "minLength": 1},
                "summary": {"type": "string", "minLength": 1},
                "story_event_ids": {"type": "array", "items": {"type": "string"}}
              }
            }
          }
        }
      }
    },
    "story_events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "description", "subject_refs", "source_semantics"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "subject_refs": {"type": "array", "items": {"type": "string"}},
          "source_semantics": {"type": "string", "enum": ["source_grounded", "inferred", "creative"]}
        }
      }
    },
    "dialogue_events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "speaker_ref", "text", "scene_id", "beat_id", "story_event_id", "source_semantics", "start_ms", "end_ms"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "speaker_ref": {"type": "string", "minLength": 1},
          "text": {"type": "string", "minLength": 1},
          "scene_id": {"type": "string", "minLength": 1},
          "beat_id": {"type": "string", "minLength": 1},
          "story_event_id": {"type": "string", "minLength": 1},
          "source_semantics": {"type": "string", "enum": ["source_grounded", "inferred", "creative"]},
          "start_ms": {"type": "integer", "minimum": 0},
          "end_ms": {"type": "integer", "minimum": 1}
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "name", "source_semantics"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "source_semantics": {"type": "string", "enum": ["source_grounded", "inferred", "creative"]}
        }
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description", "severity"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "severity": {"type": "string", "enum": ["info", "warning", "blocking"]}
        }
      }
    },
    "production_profile_override": {
      "type": "object",
      "additionalProperties": false,
      "required": ["aspect_width", "aspect_height", "duration_min_seconds", "duration_max_seconds", "shot_min", "shot_max"],
      "properties": {
        "aspect_width": {"type": ["integer", "null"], "minimum": 1},
        "aspect_height": {"type": ["integer", "null"], "minimum": 1},
        "duration_min_seconds": {"type": ["integer", "null"], "minimum": 1},
        "duration_max_seconds": {"type": ["integer", "null"], "minimum": 1},
        "shot_min": {"type": ["integer", "null"], "minimum": 1},
        "shot_max": {"type": ["integer", "null"], "minimum": 1}
      }
    }
  }
}
